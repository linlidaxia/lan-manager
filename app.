"""局域网设备管理Web应用 - LAN Device Manager"""
import os, sqlite3, socket, subprocess, time, platform
from datetime import datetime
from flask import Flask, request, jsonify, g, send_from_directory
from flask_cors import CORS

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DATA_DIR = os.path.join(BASE_DIR, 'data')
os.makedirs(DATA_DIR, exist_ok=True)
DATABASE = os.path.join(DATA_DIR, 'devices.db')
PORT = 5000
DEBUG = False

app = Flask(__name__)
CORS(app)

def init_db():
    conn = sqlite3.connect(DATABASE)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS devices (id INTEGER PRIMARY KEY, ip_address TEXT UNIQUE, mac_address TEXT, hostname TEXT, device_type TEXT, vendor TEXT, is_online INTEGER DEFAULT 0, latency REAL, last_seen DATETIME, notes TEXT, is_favorite INTEGER DEFAULT 0)''')
    c.execute('''CREATE TABLE IF NOT EXISTS ports (id INTEGER PRIMARY KEY, device_id INTEGER, port INTEGER, protocol TEXT, service TEXT, status TEXT, notes TEXT)''')
    c.execute('''CREATE TABLE IF NOT EXISTS scan_logs (id INTEGER PRIMARY KEY, devices_found INTEGER, scan_type TEXT, duration REAL)''')
    c.execute('''CREATE TABLE IF NOT EXISTS settings (key TEXT PRIMARY KEY, value TEXT)''')
    for k,v in {'auto_scan':'false','scan_interval':'60','scan_ports':'22,80,443,33,89,80,80'}.items():
        c.execute('INSERT OR IGNORE INTO settings (key,value) VALUES (?,?)',(k,v))
    conn.commit(); conn.close()

def get_db():
    db = getattr(g,'_database',None)
    if db is None: db = g._database = sqlite3.connect(DATABASE); db.row_factory = sqlite3.Row
    return db

@app.teardown_request
def close(exc): db = getattr(g,'_database',None); db.close() if db else None

def get_local_ip():
    try: s=socket.socket(); s.connect(('8.8.8.8',80)); ip=s.getsockname()[0]; s.close(); return ip
    except: return '192.168.1.100'

def get_network():
    ip = get_local_ip(); p=ip.split('.'); return {'local_ip':ip,'network':f"{p[0]}.{p[1]}.{p[2]}","cidr":f"{p[0]}.{p[1]}.{p[2]}.0/24"}

def get_vendor(mac):
    m={'00:50:56':'VMware','00:0C:29':'VMware','B8:27:EB':'RPi','DC:A6:32':'RPi','3C:06:30':'Apple','A4:5E:60':'Apple','00:14:6C':'Netgear','44:94:FC':'Netgear','00:1D:0F':'TP-Link','50:C7:BF':'TP-Link','5C:A6:E6':'Xiaomi','34:80:B3':'Xiaomi'}
    return m.get(mac[:8].upper() if mac else '', 'Unknown')

def scan_network(cidr):
    import concurrent.futures
    t0 = time.time(); ips = []; local_ip = get_local_ip()
    print(f"Scanning: {cidr}")
    try:
        import shutil
        if shutil.which('nmap'):
            print("Using nmap...")
            r = subprocess.run(['nmap','-sn','-PR','-oG','-',cidr], capture_output=True, text=True, timeout=30)
            for l in r.stdout.split('\n'):
                if 'Up' in l and '$' in l:
                    for p in l.split():
                        if p.startswith('$') and not p.startswith('$MAC'):
                            ip = p[1:]
                            if '.' in ip and ip!=local_ip: ips.append(ip)
            print(f"nmap found: {len(ips)}")
    except Exception as e: print(f"nmap failed: {e}")
    if len(ips) < 2:
        print("Using ping scan...")
        net = get_network()['network']
        pc = ['ping','-n','1','-w','200'] if platform.system()=='Windows' else ['ping','-c','1','-W','2']
        def ck(ip): r=subprocess.run(pc+[ip],capture_output=True,timeout=2); return ip if r.returncode==0 and ip!=local_ip else None
        with concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:
            for f in concurrent.futures.as_completed([ex.submit(ck,f"{net}.{i}") for i in range(1,255)]):
                if f.result(): ips.append(f.result())
        print(f"ping found: {len(ips)}")
    db = get_db(); cur = db.cursor()
    for ip in ips:
        try: mac, host = None, None
        except: pass
        lat = 0
        try: r=subprocess.run(pc+[ip],capture_output=True,text=True,timeout=2); lat=float(r.stdout.split('time=')[1].split()[0]) if 'time=' in r.stdout else 0
        except: pass
        try: cur.execute('INSERT OR REPLACE INTO devices (ip_address,mac_address,hostname,vendor,is_online,latency,last_seen) VALUES (?,?,?,?,1,?,?)',(ip,mac,host,get_vendor(mac),lat,datetime.now()))
        except: pass
    db.commit()
    cur.execute('UPDATE devices SET is_online=0 WHERE last_seen<?',(datetime.now(),)); db.commit()
    cur.execute('INSERT INTO scan_logs (devices_found,scan_type,duration) VALUES (?,?,?)',(len(ips),'network',time.time()-t0)); db.commit()
    return len(ips)

@app.route('/')
def idx(): return send_from_directory(os.path.join(BASE_DIR,'templates'),'index.html')

@app.route('/api/network')
def net(): return jsonify(get_network())

@app.route('/api/devices')
def devices():
    db=get_db(); q='SELECT * FROM devices WHERE 1=1'; p=[]
    if s:=request.args.get('search'): q+=' AND (ip_address LIKE ? OR hostname LIKE ? OR vendor LIKE ?)'; p=[f'%{s}%']*3
    if request.args.get('online')=='true': q+=' AND is_online=1'
    return jsonify([dict(r) for r in db.execute(q,p).fetchall()])

@app.route('/api/devices/<int:id>')
def device(id):
    db=get_db(); d=db.execute('SELECT * FROM devices WHERE id=?',(id,)).fetchone()
    if not d: return jsonify({'error':'not found'}),404
    return jsonify({**dict(d),'ports':[dict(p) for p in db.execute('SELECT * FROM ports WHERE device_id=?',(id,)).fetchall()]})

@app.route('/api/devices/<int:id>', methods=['PUT'])
def upd_dev(id):
    db=get_db(); d=request.get_json()
    if 'notes' in d: db.execute('UPDATE devices SET notes=? WHERE id=?',(d['notes'],id))
    if 'is_favorite' in d: db.execute('UPDATE devices SET is_favorite=? WHERE id=?',(1 if d['is_favorite'] else 0,id))
    db.commit(); return jsonify({'success':True})

@app.route('/api/devices/scan', methods=['POST'])
def scan(): count=scan_network(get_network()['cidr']); return jsonify({'success':True,'devices_found':count,'message':f'Found {count} devices'})

@app.route('/api/ports/<int:id>', methods=['PUT'])
def upd_port(id):
    db=get_db()
    if 'notes' in request.get_json(): db.execute('UPDATE ports SET notes=? WHERE id=?',(request.get_json()['notes'],id)); db.commit()
    return jsonify({'success':True})

@app.route('/api/ports/<int:id>', methods=['DELETE'])
def del_port(id): get_db().execute('DELETE FROM ports WHERE id=?',(id,)); return jsonify({'success':True})

@app.route('/api/logs')
def logs(): return jsonify([dict(r) for r in get_db().execute('SELECT * FROM scan_logs ORDER BY created_at DESC LIMIT 20').fetchall()])

@app.route('/api/settings')
def sets(): return jsonify({r['key']:r['value'] for r in get_db().execute('SELECT * FROM settings').fetchall()})

@app.route('/api/settings', methods=['PUT'])
def upd_sets():
    db=get_db()
    for k,v in request.get_json().items(): db.execute('INSERT OR REPLACE INTO settings (key,value) VALUES (?,?)',(k,str(v)))
    db.commit(); return jsonify({'success':True})

@app.route('/api/stats')
def stats():
    db=get_db(); return jsonify({'total_devices':db.execute('SELECT COUNT(*) FROM devices').fetchone()[0],'onlie_devices':db.execute('SELECT COUNT(*) FROM devices WHERE is_online=1').fetchone()[0],'favorite_devices':db.execute('SELECT COUNT(*) FROM devices WHERE is_favorite=1').fetchone()[0],'open_ports':0})

if __name__=='__main__':
    import socket
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    test_port = PORT
    while test_port < PORT + 10:
        try:
            s.bind(('0.0.0.0', test_port))
            s.close()
            actual_port = test_port
            break
        except:
            test_port += 1
    else:
        print('All ports in use!')
        actual_port = 0
    print(f'Starting on port {actual_port}...')
    init_db()
    print('========================================')
    print('  LAN Device Manager Started')
    print('  URL: http://localhost:5000')
    print('========================================')
    app.run(host="0.0.0.0", port=actual_port, debug=DEBUG)
